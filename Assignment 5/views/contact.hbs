<section class="page-hero page-hero--mini">
  <div class="page-hero-bg">
    <img src="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1400&q=80" alt="Contact" />
    <div class="page-hero-overlay"></div>
  </div>
  <div class="page-hero-content">
    <p class="section-eyebrow">Reach Out</p>
    <h1>Let's Talk Travel</h1>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-layout">
      <div class="contact-form-wrap">
        <div class="form-card">
          <h2>Send Us a Message</h2>
          <form action="/contact" method="POST" class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Your Name *</label>
                <input type="text" id="name" name="name" required placeholder="Full name" />
              </div>
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="your@email.com" />
              </div>
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <select id="subject" name="subject">
                <option value="general">General Inquiry</option>
                <option value="booking">Booking Assistance</option>
                <option value="custom">Custom Itinerary Request</option>
                <option value="group">Group Travel</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="6" required
                placeholder="Tell us about your dream journey, or any questions you have..."></textarea>
            </div>
            <button type="submit" class="btn-primary btn-block">Send Message</button>
          </form>
        </div>
      </div>

      <aside class="contact-sidebar">
        <div class="contact-info-card">
          <h3>Get in Touch</h3>
          <div class="contact-info-item">
            <div class="ci-icon">📞</div>
            <div>
              <div class="ci-label">Phone</div>
              <a href="tel:+919876543210">+91 98765 43210</a>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="ci-icon">✉</div>
            <div>
              <div class="ci-label">Email</div>
              <a href="mailto:hello@wanderlust.travel">hello@wanderlust.travel</a>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="ci-icon">📍</div>
            <div>
              <div class="ci-label">Studio</div>
              <span>14 Marine Drive, Mumbai 400020, India</span>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="ci-icon">🕐</div>
            <div>
              <div class="ci-label">Hours</div>
              <span>Mon–Sat, 9am – 7pm IST</span>
            </div>
          </div>
        </div>
        <div class="contact-info-card contact-info-card--accent">
          <h4>✦ Emergency Travel Support</h4>
          <p>Already on a journey? Our 24/7 line is always open for active travelers.</p>
          <a href="tel:+919876500000" class="btn-outline btn-block">+91 98765 00000</a>
        </div>
      </aside>
    </div>
  </div>
</section>
